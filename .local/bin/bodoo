#!/usr/bin/env bash
set -euo pipefail

SCRIPT_NAME="odoobot"

show_help() {
  cat <<EOF
Usage:
  ${SCRIPT_NAME} <function> [optional args...]
  ${SCRIPT_NAME} --help

Description:
    Script for running Odoo locally via AI agents. It assumes the current working directory is an Odoo module.
  - function: chooses which script branch runs

Supported functions:
  version
  server
  upgrade
  install
  dropdb
  tests [optional --no-coverage]
  translate <lang>

Optional args are passed into odoo-bin, unless the function specifies a separate meaning for them.
EOF
}


extract_odoo_python_pairs() {
  local po_file=$1

  awk -v out="$SAVED_TSV" '
  function reset_entry() {
      is_odoo_python = 0
      in_msgid = 0
      in_msgstr = 0
      msgid = ""
      msgstr = ""
  }

  function po_unquote(line, s) {
      s = line
      sub(/^[[:space:]]*"/, "", s)
      sub(/"[[:space:]]*$/, "", s)
      gsub(/\\n/, "\n", s)
      gsub(/\\"/, "\"", s)
      gsub(/\\\\/, "\\", s)
      return s
  }

  function po_escape(str, s) {
      s = str
      gsub(/\\/, "\\\\", s)
      gsub(/\t/, "\\t", s)
      gsub(/\r/, "\\r", s)
      gsub(/\n/, "\\n", s)
      gsub(/"/, "\\\"", s)
      return s
  }

  function flush_entry() {
      if (is_odoo_python && msgid != "" && msgstr != "") {
          print po_escape(msgid) "\t" po_escape(msgstr) >> out
      }
      reset_entry()
  }

  BEGIN {
      reset_entry()
  }

  /^[[:space:]]*$/ {
      flush_entry()
      next
  }

  /^#\./ {
      if ($0 ~ /odoo-python/) {
          is_odoo_python = 1
      }
      next
  }

  /^msgid[[:space:]]+"/ {
      in_msgid = 1
      in_msgstr = 0
      msgid = po_unquote(substr($0, index($0, "\"")))
      next
  }

  /^msgstr[[:space:]]+"/ {
      in_msgid = 0
      in_msgstr = 1
      msgstr = po_unquote(substr($0, index($0, "\"")))
      next
  }

  /^[[:space:]]*"/ {
      if (in_msgid) {
          msgid = msgid po_unquote($0)
      } else if (in_msgstr) {
          msgstr = msgstr po_unquote($0)
      }
      next
  }

  END {
      flush_entry()
  }
  ' "$po_file"
}

restore_odoo_python_pairs() {
  local po_file=$1

  awk -v saved="$SAVED_TSV" '
  function load_saved(   line, tabpos, k, v) {
      while ((getline line < saved) > 0) {
          tabpos = index(line, "\t")
          if (tabpos > 0) {
              k = substr(line, 1, tabpos - 1)
              v = substr(line, tabpos + 1)
              saved_map[k] = v
          }
      }
      close(saved)
  }

  function reset_entry() {
      entry_count = 0
      is_odoo_python = 0
      in_msgid = 0
      in_msgstr = 0
      msgid = ""
      msgstr_started = 0
  }

  function append_line(line) {
      entry_lines[++entry_count] = line
  }

  function po_unquote(line, s) {
      s = line
      sub(/^[[:space:]]*"/, "", s)
      sub(/"[[:space:]]*$/, "", s)
      gsub(/\\n/, "\n", s)
      gsub(/\\"/, "\"", s)
      gsub(/\\\\/, "\\", s)
      return s
  }

  function po_unescape(str, s) {
      s = str
      gsub(/\\n/, "\n", s)
      gsub(/\\"/, "\"", s)
      gsub(/\\\\/, "\\", s)
      return s
  }

  function po_escape(str, s) {
      s = str
      gsub(/\\/, "\\\\", s)
      gsub(/"/, "\\\"", s)
      gsub(/\n/, "\\n\"\n\"", s)
      return s
  }

  function flush_entry(   i, key, restored, replaced) {
      if (entry_count == 0) {
          return
      }

      key = msgid
      restored = 0

      if (is_odoo_python && key != "" && (key in saved_map)) {
          replaced = po_unescape(saved_map[key])

          for (i = 1; i <= entry_count; i++) {
              if (entry_lines[i] ~ /^msgstr[[:space:]]+"/) {
                  print "msgstr \"" po_escape(replaced) "\""
                  i++
                  while (i <= entry_count && entry_lines[i] ~ /^[[:space:]]*"/) {
                      i++
                  }
                  for (; i <= entry_count; i++) {
                      print entry_lines[i]
                  }
                  restored = 1
                  break
              } else {
                  print entry_lines[i]
              }
          }
      }

      if (!restored) {
          for (i = 1; i <= entry_count; i++) {
              print entry_lines[i]
          }
      }

      print ""
      reset_entry()
  }

  BEGIN {
      load_saved()
      reset_entry()
  }

  /^[[:space:]]*$/ {
      flush_entry()
      next
  }

  {
      append_line($0)
  }

  /^#\./ {
      if ($0 ~ /odoo-python/) {
          is_odoo_python = 1
      }
      next
  }

  /^msgid[[:space:]]+"/ {
      in_msgid = 1
      in_msgstr = 0
      msgid = po_unquote(substr($0, index($0, "\"")))
      next
  }

  /^msgstr[[:space:]]+"/ {
      in_msgid = 0
      in_msgstr = 1
      next
  }

  /^[[:space:]]*"/ {
      if (in_msgid) {
          msgid = msgid po_unquote($0)
      }
      next
  }

  END {
      flush_entry()
  }
  ' "$po_file" > "$po_file.tmp"

  mv "$po_file.tmp" "$po_file"
}


ensure_odoo_env() {
    local dir="$PWD"

    while [[ "$dir" != "/" ]]; do
        if [[ -f "$dir/odoorc.env" ]]; then
            source $dir/odoorc.env
            return 0
        fi
        dir="$(dirname "$dir")"
    done

    echo "Error: odoorc.env does not exist in any parent dir." >&2
    exit 1
}

ensure_odoo_config() {
    local dir="$PWD"

    while [[ "$dir" != "/" ]]; do
        if [[ -f "$dir/odoorc.conf" ]]; then
            export ODOO_CONFIG_FILE="$dir/odoorc.conf"
            return 0
        fi
        dir="$(dirname "$dir")"
    done

    echo "Error: odoorc.conf does not exist in any parent dir." >&2
    exit 1
}

ensure_manifest() {
    if [[ ! -f "__manifest__.py" ]]; then
        echo "Error: __manifest__.py does not exist. $ODOO_MODULE is not an odoo module." >&2
        exit 1
    fi
}

run_version() {
    echo "$ODOO_VERSION"
}

run_server() {
    $ODOO_VENV/python $ODOO_VERSION_DIR/odoo/odoo-bin $* --conf $ODOO_CONFIG_FILE -d $ODOO_DATABASE --db-filter "^$ODOO_DATABASE$"
}
run_upgrade() {
    $ODOO_VENV/python $ODOO_VERSION_DIR/odoo/odoo-bin $* --conf $ODOO_CONFIG_FILE -d $ODOO_DATABASE --db-filter "^$ODOO_DATABASE$" -u $ODOO_MODULE --stop-after-init --http-port=0
}
run_dropdb() {
    dropdb $ODOO_DATABASE 2>/dev/null || :
}
run_install() {
    echo "Install $ODOO_MODULE"
    $ODOO_VENV/python $ODOO_VERSION_DIR/odoo/odoo-bin $* --conf $ODOO_CONFIG_FILE -d $ODOO_DATABASE --db-filter "^$ODOO_DATABASE$" --load-language=en_US -i $ODOO_MODULE --stop-after-init --http-port=0
}
run_tests() {
    local use_coverage=1 arg
    local -a args=()
    for arg in "$@"; do [[ "$arg" == "--no-coverage" ]] && use_coverage=0 || args+=("$arg"); done

    set -- "${args[@]}" --conf $ODOO_CONFIG_FILE -d $ODOO_DATABASE --db-filter "^$ODOO_DATABASE$" -u $ODOO_MODULE --stop-after-init --http-port=0 --test-enable --test-tags=$ODOO_MODULE

    if (( use_coverage )); then
        $ODOO_VENV/python -m coverage run --omit=__manifest__.py --source="$PWD" "$ODOO_VERSION_DIR/odoo/odoo-bin" "$@"
        $ODOO_VENV/python -m coverage report -m
    else
        $ODOO_VENV/python $ODOO_VERSION_DIR/odoo/odoo-bin "$@"
    fi
}
run_translate() {
    run_upgrade
    mkdir -p i18n
    touch i18n/$1.po
    SAVED_TSV="i18n/saved.tsv"
    trap 'rm -rf "i18n/saved.tsv"' EXIT


    extract_odoo_python_pairs "i18n/$1.po"
    if (( ODOO_VERSION <= 18 )); then
        $ODOO_VENV/python $ODOO_VERSION_DIR/odoo/odoo-bin --conf $ODOO_CONFIG_FILE -d $ODOO_DATABASE -u $ODOO_MODULE --load-language=fi_FI --stop-after-init
        $ODOO_VENV/python $ODOO_VERSION_DIR/odoo/odoo-bin --i18n-export=i18n/$1.po --conf $ODOO_CONFIG_FILE -d $ODOO_DATABASE --modules=$ODOO_MODULE --language=fi_FI
    else
        $ODOO_VENV/python $ODOO_VERSION_DIR/odoo/odoo-bin i18n loadlang --conf $ODOO_CONFIG_FILE -d $ODOO_DATABASE --languages=$1
        $ODOO_VENV/python $ODOO_VERSION_DIR/odoo/odoo-bin i18n export --conf $ODOO_CONFIG_FILE -d $ODOO_DATABASE $ODOO_MODULE --languages=$1
    fi
    restore_odoo_python_pairs "i18n/$1.po"
}

if [[ $# -lt 1 ]]; then
  echo "Error: missing required arguments."
  echo
  show_help
  exit 1
fi

export ODOO_FUNCTION="$1"
shift

if [[ "$ODOO_FUNCTION" == "--help" || "$ODOO_FUNCTION" == "-h" || "$ODOO_FUNCTION" == "help" ]]; then
  show_help
  exit 0
fi

# Set ODOO_VERSION first
ensure_odoo_env
ensure_odoo_config

export ODOO_VENV="$HOME/.venv/odoo$ODOO_VERSION/bin"
export ODOO_VERSION_DIR=$HOME"/Odoo/src/${ODOO_VERSION}"
export ODOO_MODULE="$(basename "$PWD")"
export ODOO_DATABASE="$ODOO_VERSION-$ODOO_MODULE"

# Requires the exported vars above.
ensure_manifest

case "${ODOO_FUNCTION}" in
  version)
    run_version
    ;;
  server)
    run_server "$@"
    ;;
  upgrade)
    run_upgrade "$@"
    ;;
  install)
    run_install "$@"
    ;;
  dropdb)
    run_dropdb "$@"
    ;;
  tests)
    run_tests "$@"
    ;;
  translate)
    run_translate "$@"
    ;;
  --help|-h|help)
    show_help
    ;;
  *)
    echo "Error: unknown function '${ODOO_FUNCTION}'."
    echo
    show_help
    exit 1
    ;;
esac
