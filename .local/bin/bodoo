#!/usr/bin/env bash
set -euo pipefail

SCRIPT_NAME="bodoo"

show_help() {
  cat <<EOF
Usage:
  ${SCRIPT_NAME} [function] [optional args...]
  ${SCRIPT_NAME} [odoo-bin args...]
  ${SCRIPT_NAME} --help

Description:
  Script for running Odoo locally via AI agents. It assumes the current working directory is an Odoo module.
  - function: optional, chooses a non-server branch.

  This is **Odoo version ${ODOO_VERSION}**. Odoo core code can be found from ~/Odoo/src/${ODOO_VERSION}/odoo/ and ~/Odoo/src/${ODOO_VERSION}/enterprise/.

Supported functions:
  upgrade
  install
  dropdb
  tests [optional --no-coverage]
  translate <lang>

Default behavior:
  Runs the Odoo server (run_server) when no function is selected.

Optional args are passed into odoo-bin, unless the function specifies a separate meaning for them.
EOF
}


extract_odoo_python_pairs() {
  local po_file=$1
  extract_odoo_python_pairs.awk "$po_file" "$SAVED_TSV"
}

restore_odoo_python_pairs() {
  local po_file=$1
  restore_odoo_python_pairs.awk "$po_file" "$SAVED_TSV" > "$po_file.tmp"

  mv "$po_file.tmp" "$po_file"
}

ensure_odoo_env() {
    local dir="$PWD"

    while [[ "$dir" != "/" ]]; do
        if [[ -f "$dir/odoorc.env" ]]; then
            source $dir/odoorc.env
            return 0
        fi
        dir="$(dirname "$dir")"
    done

    echo "Error: odoorc.env does not exist in any parent dir." >&2
    exit 1
}

ensure_odoo_config() {
    local dir="$PWD"

    while [[ "$dir" != "/" ]]; do
        if [[ -f "$dir/odoorc.conf" ]]; then
            export ODOO_CONFIG_FILE="$dir/odoorc.conf"
            return 0
        fi
        dir="$(dirname "$dir")"
    done

    echo "Error: odoorc.conf does not exist in any parent dir." >&2
    exit 1
}

ensure_manifest() {
    if [[ ! -f "__manifest__.py" ]]; then
        echo "Error: __manifest__.py does not exist. $ODOO_MODULE is not an odoo module." >&2
        exit 1
    fi
}

run_server() {
    $ODOO_VENV/python $ODOO_VERSION_DIR/odoo/odoo-bin $* --conf $ODOO_CONFIG_FILE -d $ODOO_DATABASE --db-filter "^$ODOO_DATABASE$"
}
run_upgrade() {
    $ODOO_VENV/python $ODOO_VERSION_DIR/odoo/odoo-bin $* --conf $ODOO_CONFIG_FILE -d $ODOO_DATABASE --db-filter "^$ODOO_DATABASE$" -u $ODOO_MODULE --stop-after-init --http-port=0
}
run_dropdb() {
    dropdb $ODOO_DATABASE 2>/dev/null || :
}
run_install() {
    echo "Install $ODOO_MODULE"
    $ODOO_VENV/python $ODOO_VERSION_DIR/odoo/odoo-bin $* --conf $ODOO_CONFIG_FILE -d $ODOO_DATABASE --db-filter "^$ODOO_DATABASE$" --load-language=en_US -i $ODOO_MODULE --stop-after-init --http-port=0
}
run_tests() {
    local use_coverage=1 arg
    local -a args=()
    for arg in "$@"; do [[ "$arg" == "--no-coverage" ]] && use_coverage=0 || args+=("$arg"); done

    set -- "${args[@]}" --conf $ODOO_CONFIG_FILE -d $ODOO_DATABASE --db-filter "^$ODOO_DATABASE$" -u $ODOO_MODULE --stop-after-init --http-port=0 --test-enable --test-tags=$ODOO_MODULE

    if (( use_coverage )); then
        $ODOO_VENV/python -m coverage run --omit=__manifest__.py --source="$PWD" "$ODOO_VERSION_DIR/odoo/odoo-bin" "$@"
        $ODOO_VENV/python -m coverage report -m
    else
        $ODOO_VENV/python $ODOO_VERSION_DIR/odoo/odoo-bin "$@"
    fi
}
run_translate() {
    run_upgrade
    mkdir -p i18n
    touch i18n/$1.po
    SAVED_TSV="i18n/saved.tsv"
    trap 'rm -rf "i18n/saved.tsv"' EXIT


    extract_odoo_python_pairs "i18n/$1.po"
    if (( ODOO_VERSION <= 18 )); then
        $ODOO_VENV/python $ODOO_VERSION_DIR/odoo/odoo-bin --conf $ODOO_CONFIG_FILE -d $ODOO_DATABASE -u $ODOO_MODULE --load-language=fi_FI --stop-after-init
        $ODOO_VENV/python $ODOO_VERSION_DIR/odoo/odoo-bin --i18n-export=i18n/$1.po --conf $ODOO_CONFIG_FILE -d $ODOO_DATABASE --modules=$ODOO_MODULE --language=fi_FI
    else
        $ODOO_VENV/python $ODOO_VERSION_DIR/odoo/odoo-bin i18n loadlang --conf $ODOO_CONFIG_FILE -d $ODOO_DATABASE --languages=$1
        $ODOO_VENV/python $ODOO_VERSION_DIR/odoo/odoo-bin i18n export --conf $ODOO_CONFIG_FILE -d $ODOO_DATABASE $ODOO_MODULE --languages=$1
    fi
    restore_odoo_python_pairs "i18n/$1.po"
}



# Set ODOO_VERSION first
ensure_odoo_env


export ODOO_FUNCTION=""
if [[ $# -gt 0 ]]; then
  case "$1" in
    --help|-h|help)
      show_help
      exit 0
      ;;
    upgrade|install|dropdb|tests|translate)
      export ODOO_FUNCTION="$1"
      shift
      ;;
    *)
      # No function selected: default to server and pass all args through.
      ;;
  esac
fi


ensure_odoo_config

export ODOO_VENV="$HOME/.venv/odoo$ODOO_VERSION/bin"
export ODOO_VERSION_DIR=$HOME"/Odoo/src/${ODOO_VERSION}"
export ODOO_MODULE="$(basename "$PWD")"
export ODOO_DATABASE="$ODOO_VERSION-$ODOO_MODULE"

# Requires the exported vars above.
ensure_manifest

case "${ODOO_FUNCTION}" in
  upgrade)
    run_upgrade "$@"
    ;;
  install)
    run_install "$@"
    ;;
  dropdb)
    run_dropdb "$@"
    ;;
  tests)
    run_tests "$@"
    ;;
  translate)
    run_translate "$@"
    ;;
  --help|-h|help)
    show_help
    ;;
  "")
    run_server "$@"
    ;;
  *)
    echo "Error: unknown function '${ODOO_FUNCTION}'."
    echo
    show_help
    exit 1
    ;;
esac
